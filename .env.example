# =========================
# Environment
# =========================
ENV=dev   # dev | staging | prod


# =========================
# Browser (optional override)
# =========================
HEADLESS=true   # true | false


# =========================
# API
# =========================
API_KEY=your_api_key_here
API_TIMEOUT=10


# =========================
# Auth (only if needed by tests)
# =========================
DEV_USERNAME=
DEV_PASSWORD=

STAGE_USERNAME=
STAGE_PASSWORD=

PROD_USERNAME=
PROD_PASSWORD=


# =========================
# Reporting
# =========================
ALLURE_RESULTS_DIR=reports/allure-results

